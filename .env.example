# Environment Variables for n8n Multi-Agent Coding Pipeline
# Copy this file to .env and fill in your actual values

# Domain Configuration (set these BEFORE first deployment)
SUBDOMAIN=n8n
DOMAIN_NAME=localhost  # Change to your actual domain, e.g., n8n.example.com

# n8n URLs (should match your server configuration)
N8N_EDITOR_BASE_URL=https://n8n.yourdomain.com
WEBHOOK_URL=https://n8n.yourdomain.com

# Timezone Configuration
GENERIC_TIMEZONE=America/New_York
TZ=America/New_York

# LM Studio API Key (used by all agents via Bearer token)
# Set in LM Studio → Server → API Key, then copy it here
LLM_API_KEY=your-lm-studio-api-key

# LM Studio base URL (used by HTTP Request nodes in all agents)
LOCAL_AI_BASE_URL=http://10.0.0.100:1234/v1

# NOTE: Models are now hardcoded per-agent in their Build Request / Prepare Message nodes:
#   Planner, Security, Quality reviewers → qwen/qwen3.5-9b
#   Code Writer                          → qwen/qwen2.5-coder-32b-instruct
# To change models, edit the jsCode in each workflow's Build Request node.

# Security Settings (do not change unless you understand the implications)
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true
NODE_FUNCTION_ALLOW_BUILTIN=https,http,url,querystring,path,os
NODE_FUNCTION_ALLOW_EXTERNAL=*
N8N_COMMUNITY_PACKAGES_ALLOW_TOOL_USAGE=true

# File API token — must match FILE_API_TOKEN in /docker/stacks/file-api/.env
FILE_API_TOKEN=your-file-api-token

# Notes:
# - LOCAL_AI_BASE_URL must point to your LM Studio instance
# - LLM_API_KEY is referenced as $env.LLM_API_KEY in all HTTP Request nodes
# - FILE_API_TOKEN is used by the Write Files node in 07-Task-Processor
# - Redis is no longer required — Code Writer now uses direct HTTP (no session memory)
