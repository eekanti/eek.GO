# n8n Pipeline Environment Variables
# Copy to /n8n-team/workflows/.env and /docker/stacks/n8n/.env with your actual values

# LM Studio
LLM_API_KEY=your-lm-studio-api-key
LM_STUDIO_URL=http://your-host-ip:1234/v1/chat/completions

# Models
PLANNER_MODEL=qwen/qwen3.5-9b
CODER_MODEL=qwen/qwen2.5-coder-32b-instruct
REVIEWER_MODEL=qwen/qwen3.5-9b

# File API
FILE_API_URL=http://file-api:3456
FILE_API_TOKEN=your-file-api-token

# MCP Gateway (Context7)
MCP_GATEWAY_URL=http://docky:8811/mcp

# n8n API
N8N_API_KEY=your-n8n-api-key

# Workflow IDs (update after deploying workflows to your n8n instance)
WF_MASTER_ORCHESTRATOR=
WF_PLANNER=
WF_CODE_WRITER=
WF_PROJECT_MEMORY=
WF_TASK_PROCESSOR=
WF_COMBINED_REVIEWER=
WF_CHUNK_PROCESSOR=
WF_RESEARCH_AGENT=
