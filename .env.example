# Environment Variables Template for Plexie Server
# Copy this file to .env and fill in your actual values

# Domain Configuration (set these BEFORE first deployment)
SUBDOMAIN=plexie
DOMAIN_NAME=localhost  # Change to your actual domain if using one, e.g., plexie.example.com

# n8n URLs (should match your server configuration)
N8N_EDITOR_BASE_URL=https://plexie.yourdomain.com
WEBHOOK_URL=https://plexie.yourdomain.com

# Timezone Configuration
GENERIC_TIMEZONE=America/New_York
TZ=America/New_York

# LM Studio Local LLM Configuration
LOCAL_AI_BASE_URL=http://10.0.0.100:1234/v1
LOCAL_AI_MODEL=mistral-7b-instruct-v0.2  # Change to your actual model name from LM Studio

# Security Settings (do not change unless you understand the implications)
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true
NODE_FUNCTION_ALLOW_BUILTIN=https,http,url,querystring,path,os
NODE_FUNCTION_ALLOW_EXTERNAL=*
N8N_COMMUNITY_PACKAGES_ALLOW_TOOL_USAGE=true
N8N_CUSTOM_EXTENSIONS=n8n-nodes-langchain

# Optional: Redis Configuration (for better performance)
REDIS_URL=redis://plexie-redis:6379

# Notes:
# - LOCAL_AI_BASE_URL must point to your LM Studio instance at 10.0.0.100:1234
# - LOCAL_AI_MODEL should match the exact model name loaded in LM Studio
#   You can check this by going to http://10.0.0.100:1234/v1/models in your browser
# - DOMAIN_NAME should be your actual server domain or localhost for testing
